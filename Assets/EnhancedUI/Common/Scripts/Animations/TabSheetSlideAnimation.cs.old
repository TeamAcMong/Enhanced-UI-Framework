using UnityEngine;
using UnityScreenNavigator.Runtime.Core.Shared;
using UnityScreenNavigator.Runtime.Foundation.Animation;

namespace EnhancedUI.Demo.Animations
{
    /// <summary>
    /// Horizontal slide animation for tab sheets
    /// Automatically determines slide direction based on tab indices
    /// Example: Moving from tab 0 to tab 1 slides left, from tab 1 to tab 0 slides right
    /// </summary>
    public class TabSheetSlideAnimation : TransitionAnimationBehaviour
    {
        [Header("Animation Settings")]
        [SerializeField] private float duration = 0.3f;
        [SerializeField] private EaseType easeType = EaseType.QuadraticEaseOut;

        [Header("Animation Type")]
        [SerializeField] private bool isEnterAnimation = true;

        private Vector3 _beforePosition;
        private Vector3 _afterPosition;
        private int _tabIndex;
        private int _partnerTabIndex;

        public override float Duration => duration;

        public override void Setup()
        {
            // Get tab indices from ITabContent interface
            var tabContent = RectTransform.GetComponent<ITabContent>();
            var partnerTabContent = PartnerRectTransform?.GetComponent<ITabContent>();

            if (tabContent != null)
            {
                _tabIndex = tabContent.TabIndex;
            }
            else
            {
                Debug.LogWarning($"[TabSheetSlideAnimation] {RectTransform.name} does not implement ITabContent!");
                _tabIndex = 0;
            }

            if (partnerTabContent != null)
            {
                _partnerTabIndex = partnerTabContent.TabIndex;
            }
            else
            {
                // No partner (first sheet being shown)
                _partnerTabIndex = _tabIndex;
            }

            // Determine slide direction based on tab order
            SheetAlignment beforeAlignment;
            SheetAlignment afterAlignment;

            if (isEnterAnimation)
            {
                // Enter animation: slide in from off-screen
                if (_tabIndex < _partnerTabIndex)
                {
                    // Moving to a left tab: enter from left
                    beforeAlignment = SheetAlignment.Left;
                }
                else if (_tabIndex > _partnerTabIndex)
                {
                    // Moving to a right tab: enter from right
                    beforeAlignment = SheetAlignment.Right;
                }
                else
                {
                    // Same tab (initial load): already centered
                    beforeAlignment = SheetAlignment.Center;
                }

                afterAlignment = SheetAlignment.Center;
            }
            else
            {
                // Exit animation: slide out to off-screen
                beforeAlignment = SheetAlignment.Center;

                if (_tabIndex < _partnerTabIndex)
                {
                    // Moving away from a left tab: exit to left
                    afterAlignment = SheetAlignment.Left;
                }
                else if (_tabIndex > _partnerTabIndex)
                {
                    // Moving away from a right tab: exit to right
                    afterAlignment = SheetAlignment.Right;
                }
                else
                {
                    // Same tab: stay centered
                    afterAlignment = SheetAlignment.Center;
                }
            }

            // Calculate positions
            _beforePosition = beforeAlignment.ToPosition(RectTransform);
            _afterPosition = afterAlignment.ToPosition(RectTransform);

            // Debug logging
            if (Application.isEditor)
            {
                Debug.Log($"[TabSheetSlideAnimation] Setup: {RectTransform.name} " +
                         $"(Tab {_tabIndex}) {(isEnterAnimation ? "Enter" : "Exit")} " +
                         $"Partner: Tab {_partnerTabIndex} | " +
                         $"{beforeAlignment} → {afterAlignment}");
            }
        }

        public override void SetTime(float time)
        {
            if (duration <= 0f)
            {
                // Instant transition
                RectTransform.anchoredPosition = _afterPosition;
                return;
            }

            // Calculate progress with easing
            var progress = Mathf.Clamp01(time / duration);
            progress = Easings.Interpolate(progress, easeType);

            // Interpolate position
            var position = Vector3.Lerp(_beforePosition, _afterPosition, progress);
            RectTransform.anchoredPosition = position;
        }
    }
}
